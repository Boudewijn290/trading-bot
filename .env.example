# .env.example — Copy to .env and fill in your credentials
# NEVER commit .env to version control

# ── Alpaca credentials (required) ────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── Broker mode ───────────────────────────────────────────────────────────────
MODE=paper          # paper | live

# ── Market settings ───────────────────────────────────────────────────────────
SYMBOL=AAPL
ASSET_CLASS=us_equity   # us_equity | crypto
TIMEFRAME=1Hour          # 1Min | 5Min | 15Min | 30Min | 1Hour | 4Hour | 1Day
BAR_LIMIT=200            # bars fetched per cycle (for indicator warmup)
POLL_INTERVAL_SECONDS=60 # seconds between bar checks

# ── Risk controls ─────────────────────────────────────────────────────────────
MAX_POSITION_PCT=5.0     # % of account equity per trade
STOP_LOSS_PCT=           # e.g. 2.0 → stop at 2% below entry (leave blank to disable)
TAKE_PROFIT_PCT=         # e.g. 4.0 → take profit at 4% above entry (leave blank to disable)

# ── Output ────────────────────────────────────────────────────────────────────
RUNS_DIR=runs            # trade log CSV and equity chart are saved here
